+ */
+- (void)detectBarcodeInInvertedBuffer:(CVPixelBufferRef)pixelBuffer
+                          symbologies:(NSArray*)symbologies
+                     regionOfInterest:(CGRect)regionOfInterest
+                           completion:(void (^)(NSArray*))completion {
+  CIImage* ciImage = [CIImage imageWithCVPixelBuffer:pixelBuffer];
+  CIFilter* invertFilter = [CIFilter filterWithName:@"CIColorInvert"];
+  [invertFilter setValue:ciImage forKey:kCIInputImageKey];
+  CIImage* invertedImage = invertFilter.outputImage;
+
+  if (!invertedImage) {
+    completion(@[]);
+    return;
+  }
+
+  VNImageRequestHandler* handler =
+      [[VNImageRequestHandler alloc] initWithCIImage:invertedImage
+                                             options:@{}];
+  VNDetectBarcodesRequest* request = [[VNDetectBarcodesRequest alloc]
+      initWithCompletionHandler:^(VNRequest* _Nonnull request,
+                                  NSError* _Nullable error) {
+        if (error) {
+          completion(@[]);
+          return;
+        }
+        completion(request.results);
+      }];
+
+  if (@available(iOS 16.0, *)) {
+    request.revision = VNDetectBarcodesRequestRevision3;
+  }
+
+  if (symbologies.count > 0) {
+    request.symbologies = symbologies;
+  }
+
+  if (!CGRectEqualToRect(regionOfInterest, CGRectZero)) {
+    request.regionOfInterest = regionOfInterest;
+  }
+
+  NSError* error;
+  [handler performRequests:@[ request ] error:&error];
+  if (error) {
+    completion(@[]);
+  }
